# API server (the FastAPI backend in ../app/)
API_BASE_URL=http://10.0.2.2:8000

# Zitadel OIDC. The mobile app reads these via --dart-define at build
# time, so this file is just a reference. To enable OIDC login against
# the local Zitadel started by `docker-compose up -d zitadel`, run:
#
#   flutter run \
#     --dart-define=API_BASE_URL=http://10.0.2.2:8000 \
#     --dart-define=ZITADEL_ISSUER=http://10.0.2.2:8081 \
#     --dart-define=ZITADEL_CLIENT_ID=<paste-client-id-from-console> \
#     --dart-define=ZITADEL_REDIRECT_URI=com.flashcard.mobile:/oauthredirect
#
# Adjust the host:
#   - Android emulator: 10.0.2.2 (above)
#   - iOS simulator / desktop: localhost
#   - Physical device on Wi-Fi: your host machine's LAN IP
#
# Important: the host you point at MUST match ZITADEL_EXTERNAL_DOMAIN
# in docker-compose.yml. Mismatch breaks the OIDC redirect because the
# `iss` claim in tokens will not match the discovery URL the device hits.
#
# When ZITADEL_* values are missing the app falls back to the
# username/password JWT flow against the FastAPI backend.

ZITADEL_ISSUER=http://10.0.2.2:8081
ZITADEL_CLIENT_ID=
ZITADEL_REDIRECT_URI=com.flashcard.mobile:/oauthredirect
